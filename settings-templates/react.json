{
  "_readme": "Claude Code settings template for a React frontend project (CRA, Vite, or Next.js).",
  "_usage": "Copy to .claude/settings.json in your project root. Adjust allow/deny rules to match your project structure.",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(node_modules/**)",
      "Write(node_modules/**)",
      "Edit(node_modules/**)",
      "Read(.next/**)",
      "Write(.next/**)",
      "Edit(.next/**)",
      "Read(dist/**)",
      "Write(dist/**)",
      "Edit(dist/**)",
      "Read(build/**)",
      "Write(build/**)",
      "Edit(build/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-naming-conventions.sh"
          }
        ]
      }
    ]
  }
}
